{
  "name": "juliaapp-monorepo",
  "private": true,
  "packageManager": "yarn@4.9.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "node ./scripts/prepare-workspace.mjs",
    "cleanup": "node ./scripts/cleanup-workspace.mjs",
    "reset": "node ./scripts/reset-runtime.mjs",
    "dev": "yarn workspace @julia/server dev",
    "build": "yarn workspace @julia/server build",
    "build:raw": "yarn workspace @julia/server build:raw",
    "test": "yarn workspace @julia/server test",
    "lint": "yarn workspace @julia/server lint",
    "typecheck": "yarn workspace @julia/server typecheck",
    "start": "yarn workspace @julia/server start",
    "check:protocol": "yarn workspace @julia/protocol check",
    "check:agent": "yarn workspace @julia/agent check",
    "build:agent": "yarn workspace @julia/agent build",
    "dev:server": "yarn workspace @julia/server dev",
    "build:server": "yarn workspace @julia/server build",
    "test:server": "yarn workspace @julia/server test"
  }
}
