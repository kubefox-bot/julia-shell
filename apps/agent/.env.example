# Agent HTTP API base URL
JULIA_AGENT_SERVER_URL=http://127.0.0.1:4321

# Agent gRPC endpoint
JULIA_AGENT_GRPC_ENDPOINT=http://127.0.0.1:50051

# Agent id from POST /api/passport/agent/enroll-token/create
JULIA_AGENT_ID=

# One-time enrollment token from POST /api/passport/agent/enroll-token/create
JULIA_AGENT_ENROLLMENT_TOKEN=

# Optional: override where refresh session is stored
# JULIA_AGENT_REFRESH_TOKEN_PATH=$HOME/.julia-agent/session.json

# Optional: custom hostname/display name in UI
# JULIA_AGENT_DISPLAY_NAME=

# Optional: override agent version reported to server
# JULIA_AGENT_VERSION=0.1.0

# Optional: explicit binary path
# JULIA_AGENT_BIN=./julia-agent
