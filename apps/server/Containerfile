FROM node:24-alpine AS base

WORKDIR /app

RUN corepack enable && corepack prepare yarn@4.9.1 --activate

FROM base AS deps-build

COPY package.json yarn.lock .yarnrc.yml ./
COPY apps/server/package.json ./apps/server/package.json
COPY apps/agent/package.json ./apps/agent/package.json
COPY packages/protocol/package.json ./packages/protocol/package.json

RUN yarn install --immutable

FROM deps-build AS build

COPY . .

RUN yarn workspace @julia/server build

FROM base AS deps-prod

COPY package.json yarn.lock .yarnrc.yml ./
COPY apps/server/package.json ./apps/server/package.json
COPY apps/agent/package.json ./apps/agent/package.json
COPY packages/protocol/package.json ./packages/protocol/package.json

RUN yarn workspaces focus @julia/server --production

FROM node:24-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production
ENV HOST=0.0.0.0
ENV PORT=4321
ENV JULIA_AGENT_GRPC_PORT=50051

COPY --from=deps-prod /app/node_modules ./node_modules
COPY --from=deps-prod /app/package.json ./package.json
COPY --from=deps-prod /app/apps/server/package.json ./apps/server/package.json
COPY --from=build /app/apps/server/dist ./apps/server/dist
COPY --from=build /app/packages/protocol/proto ./packages/protocol/proto

EXPOSE 4321
EXPOSE 50051

CMD ["node", "./apps/server/dist/server/entry.mjs"]
