---
import Layout from '../layouts/Layout.astro';
import fs from 'fs/promises';
import path from 'path';
import os from 'os';

const DOWNLOADS_DIR = path.join(os.homedir(), 'Downloads');

// Получаем список резюме (последние 10)
let hrFiles: string[] = [];
try {
    const files = await fs.readdir(DOWNLOADS_DIR);
    hrFiles = files
        .filter(f => {
            const low = f.toLowerCase();
            return (low.includes('резюме') || low.includes('соискатель') || low.includes('cv') || low.includes('resume')) && f.endsWith('.pdf');
        })
        .sort(async (a, b) => {
            const statA = await fs.stat(path.join(DOWNLOADS_DIR, a));
            const statB = await fs.stat(path.join(DOWNLOADS_DIR, b));
            return statB.mtimeMs - statA.mtimeMs;
        })
        .slice(0, 10);
} catch (e) {
    console.error('Error reading downloads', e);
}

// Поиск книг для английского (автоматически)
let englishBooks: string[] = [];
try {
    const files = await fs.readdir(DOWNLOADS_DIR);
    englishBooks = files.filter(f => {
        const low = f.toLowerCase();
        return (low.includes('english') || low.includes('учебник') || low.includes('grammar')) && (f.endsWith('.pdf') || f.endsWith('.epub'));
    }).slice(0, 4);
} catch (e) {}

const today = new Intl.DateTimeFormat('ru-RU', { weekday: 'long', day: 'numeric', month: 'long' }).format(new Date());
---

<Layout title="Yulia Assistant">
	<header class="header">
		<h1>Привет, Юля! ✨</h1>
		<p class="date">{today}</p>
	</header>

	<div class="grid">
		<!-- Карточка: Уборка -->
		<div class="card card-wide" id="clean-card">
			<div class="card-content">
				<div class="icon">🧹</div>
				<h2>Навести порядок</h2>
				<p>Сгруппировать файлы в загрузках по категориям</p>
				<button id="clean-btn" class="btn">Запустить магию</button>
			</div>
			<div id="clean-status" class="status-overlay">Готово! ✨</div>
		</div>

		<!-- Карточка: Кандидаты -->
		<div class="card">
			<div class="icon">📄</div>
			<h2>Мои кандидаты</h2>
			<ul class="file-list">
				{hrFiles.length > 0 ? hrFiles.map(file => (
					<li>{file}</li>
				)) : <li class="empty">Пока нет резюме в загрузках</li>}
			</ul>
		</div>

		<!-- Карточка: Английский -->
		<div class="card">
			<div class="icon">🇬🇧</div>
			<h2>English Time</h2>
			<ul class="file-list">
				{englishBooks.length > 0 ? englishBooks.map(file => (
					<li>{file}</li>
				)) : <li class="empty">Учебники не найдены</li>}
			</ul>
			<a href="https://dictionary.cambridge.org/" target="_blank" class="link-btn">Словарь →</a>
		</div>

		<!-- Карточка: Книжная полка -->
		<div class="card">
			<div class="icon">📚</div>
			<h2>Книжная полка</h2>
			<p>Доступ к последним книгам (.epub, .fb2)</p>
			<button id="open-btn" class="btn btn-secondary">Открыть папку</button>
		</div>

		<!-- Карточка: Чат с помощником -->
		<div class="card card-wide chat-container">
			<div class="card-content">
				<div class="icon">💬</div>
				<h2>Написать тебе</h2>
				<div class="chat-box" id="chat-box">
					<div class="message assistant">Привет, Юля! Как дела? ✨</div>
				</div>
				<form id="chat-form" class="chat-form">
					<input type="text" id="chat-input" placeholder="Напиши что-нибудь..." required autocomplete="off" />
					<button type="submit" class="send-btn">🚀</button>
				</form>
			</div>
		</div>
	</div>

	<footer class="status-bar" id="status-bar">
		Система готова к работе.
	</footer>
</Layout>

<script>
	const cleanBtn = document.getElementById('clean-btn');
	const openBtn = document.getElementById('open-btn');
	const statusBar = document.getElementById('status-bar');
	const cleanStatus = document.getElementById('clean-status');
	
	const chatForm = document.getElementById('chat-form') as HTMLFormElement;
	const chatInput = document.getElementById('chat-input') as HTMLInputElement;
	const chatBox = document.getElementById('chat-box');

	cleanBtn?.addEventListener('click', async () => {
		if (statusBar) statusBar.textContent = 'Магическая уборка началась...';
		
		try {
			const res = await fetch('/api/clean', { method: 'POST' });
			const data = await res.json();
			
			const sizeMB = (data.size / (1024 * 1024)).toFixed(2);
			const message = data.moved > 0 
				? `Уборка завершена! Перемещено файлов: ${data.moved} (${sizeMB} MB)`
				: 'В загрузках уже идеальный порядок! ✨';
			
			if (statusBar) statusBar.textContent = message;
			if (cleanStatus) {
				cleanStatus.classList.add('active');
				setTimeout(() => cleanStatus.classList.remove('active'), 3000);
			}
		} catch (e) {
			if (statusBar) statusBar.textContent = 'Ошибка при уборке :(';
		}
	});

	openBtn?.addEventListener('click', async () => {
		try {
			await fetch('/api/open', { method: 'POST' });
		} catch (e) {
			console.error('Failed to open folder');
		}
	});

	chatForm?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const message = chatInput.value.trim();
		if (!message) return;

		// Добавляем сообщение пользователя
		addMessage(message, 'user');
		chatInput.value = '';

		try {
			const res = await fetch('/api/chat', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ message })
			});
			const data = await res.json();
			
			// Имитация задержки "печатания"
			setTimeout(() => {
				addMessage(data.reply, 'assistant');
			}, 500);
		} catch (e) {
			addMessage('Ой, что-то пошло не так... попробуй еще раз!', 'assistant');
		}
	});

	function addMessage(text: string, role: 'user' | 'assistant') {
		if (!chatBox) return;
		const msgDiv = document.createElement('div');
		msgDiv.className = `message ${role}`;
		msgDiv.textContent = text;
		chatBox.appendChild(msgDiv);
		chatBox.scrollTop = chatBox.scrollHeight;
	}
</script>

<style>
	.header {
		margin-bottom: 2rem;
	}

	h1 {
		font-size: 2.5rem;
		margin: 0;
		font-weight: 700;
	}

	.date {
		color: #888;
		text-transform: capitalize;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.5rem;
		flex-grow: 1;
	}

	.card-wide {
		grid-column: span 2;
	}

	@media (max-width: 768px) {
		.card-wide { grid-column: span 1; }
	}

	.card {
		background: var(--card-bg);
		border-radius: var(--radius);
		padding: 2rem;
		box-shadow: var(--card-shadow);
		position: relative;
		overflow: hidden;
		transition: transform 0.2s;
		display: flex;
		flex-direction: column;
	}

	.card:hover {
		transform: translateY(-5px);
	}

	.icon {
		font-size: 2.5rem;
		margin-bottom: 1rem;
	}

	h2 {
		margin: 0 0 1rem 0;
		font-size: 1.5rem;
	}

	.btn {
		background: var(--accent-rose);
		border: none;
		padding: 0.8rem 1.5rem;
		border-radius: 16px;
		font-family: inherit;
		font-weight: 600;
		cursor: pointer;
		margin-top: 1rem;
		transition: opacity 0.2s;
	}

	.btn:hover {
		opacity: 0.8;
	}

	.btn-secondary {
		background: var(--accent-lavender);
	}

	.file-list {
		list-style: none;
		padding: 0;
		margin: 0;
		font-size: 0.9rem;
	}

	.file-list li {
		padding: 0.5rem 0;
		border-bottom: 1px solid #f0f0f0;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.empty {
		color: #aaa;
		font-style: italic;
	}

	.link-btn {
		display: inline-block;
		margin-top: 1rem;
		color: #888;
		text-decoration: none;
		font-size: 0.9rem;
	}

	.status-bar {
		margin-top: 2rem;
		background: #fff;
		padding: 1rem;
		border-radius: 16px;
		font-size: 0.9rem;
		color: #666;
		box-shadow: var(--card-shadow);
	}

	.status-overlay {
		position: absolute;
		top: 0; left: 0; right: 0; bottom: 0;
		background: rgba(255,255,255,0.9);
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: bold;
		font-size: 1.5rem;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.3s;
	}

	.status-overlay.active {
		opacity: 1;
	}

	/* Chat Styles */
	.chat-container {
		max-height: 500px;
	}

	.chat-box {
		height: 250px;
		overflow-y: auto;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		margin-bottom: 1.5rem;
		padding-right: 0.5rem;
	}

	.chat-box::-webkit-scrollbar {
		width: 4px;
	}

	.chat-box::-webkit-scrollbar-thumb {
		background: #f1f1f1;
		border-radius: 10px;
	}

	.message {
		padding: 0.8rem 1.2rem;
		border-radius: 18px;
		max-width: 80%;
		font-size: 0.95rem;
		line-height: 1.4;
		word-break: break-word;
	}

	.assistant {
		background: #f1f1f1;
		color: var(--text-color);
		align-self: flex-start;
		margin-right: auto;
		border-bottom-left-radius: 4px;
	}

	.user {
		background: #f3e8ff;
		color: #5b476b;
		align-self: flex-end;
		margin-left: auto;
		border-bottom-right-radius: 4px;
	}

	.chat-form {
		display: flex;
		gap: 0.8rem;
	}

	.chat-form input {
		flex-grow: 1;
		padding: 0.8rem 1.2rem;
		border-radius: 16px;
		border: 1px solid #eee;
		font-family: inherit;
		font-size: 1rem;
		outline: none;
		transition: border-color 0.2s;
	}

	.chat-form input:focus {
		border-color: var(--accent-rose);
	}

	.send-btn {
		background: var(--text-color);
		color: white;
		border: none;
		padding: 0.8rem;
		border-radius: 16px;
		cursor: pointer;
		font-size: 1.2rem;
		transition: transform 0.2s;
	}

	.send-btn:hover {
		transform: scale(1.05);
	}
</style>
