---
import Layout from '../layouts/Layout.astro';
import { ShellApp } from '@app/shell/ui';
import { DateTime } from 'luxon';
import JuliaHeader from '@app/shell/ui/astro/julia-header/JuliaHeader.astro';
import { Meta } from '@app/shell/ui/astro/meta';
import { ShellSilhouetteGrid } from '@app/shell/ui/components';
import { buildShellSkeletonLayout } from '@app/shell/model/skeleton';
import { getDailyQuote, getShellText } from '@app/shell/lib/i18n';
import { getShellSettings } from '@core/services/shell-service';
import { PASSPORT_ANONYMOUS_AGENT_ID } from '@passport/server/config/consts';
import { resolvePassportRequestContext } from '@passport/server/context';
import { resolveDisplayLocale } from '@shared/lib/locale';
import { buildLocaleCookieHeader, parseLocaleCookie } from '@shared/lib/locale-cookie';
import { AUTO_THEME_DAY_START_HOUR, AUTO_THEME_NIGHT_START_HOUR } from '@app/shell/model/constants';
import type { ResolvedShellTheme } from '@/entities/widget/model/types';

function resolveShellTheme(theme: 'auto' | 'day' | 'night', hour: number): ResolvedShellTheme {
  if (theme === 'day' || theme === 'night') {
    return theme;
  }

  return hour >= AUTO_THEME_DAY_START_HOUR && hour < AUTO_THEME_NIGHT_START_HOUR ? 'day' : 'night';
}

const title = 'Julia Shell';
const passportContext = await resolvePassportRequestContext(Astro.request, {
  allowBootstrapFromOnlineAgent: false
});
if (passportContext.context?.setCookieHeader) {
  Astro.response.headers.append('Set-Cookie', passportContext.context.setCookieHeader);
}
const hasPassportAccess = Boolean(passportContext.context);
const initialAgentId = passportContext.context?.agentId ?? PASSPORT_ANONYMOUS_AGENT_ID;
const dbShellSettings = await getShellSettings(initialAgentId, { hasPassportAccess });
const initialNowIso = new Date().toISOString();
const cookieLocale = parseLocaleCookie(Astro.request.headers.get('cookie'));
const initialDisplayLocale = cookieLocale ?? resolveDisplayLocale(dbShellSettings.layoutSettings.locale);
const initialShellSettings = {
  ...dbShellSettings,
  layoutSettings: {
    ...dbShellSettings.layoutSettings,
    locale: initialDisplayLocale
  }
};
Astro.response.headers.append(
  'Set-Cookie',
  buildLocaleCookieHeader({ locale: initialDisplayLocale, request: Astro.request })
);
const initialNow = new Date(initialNowIso);
const initialNowLocale = DateTime.fromJSDate(initialNow).setLocale(initialDisplayLocale === 'ru' ? 'ru' : 'en');
const initialQuote = getDailyQuote(initialDisplayLocale, initialNowLocale);
const initialGreeting = getShellText(initialDisplayLocale, 'greeting');
const initialSilhouetteLayout = buildShellSkeletonLayout(initialShellSettings.layout, initialShellSettings.modules, []);
const currentHour = new Date().getHours();
const resolvedShellTheme = resolveShellTheme(initialShellSettings.layoutSettings.theme, currentHour);

---

<Layout title={title} shellTheme={resolvedShellTheme} shellLocale={initialDisplayLocale}>
  <div class="shellBootStage">
    <div id="shell-boot-overlay" class="shellBootOverlay" aria-hidden="true">
      <div class="shellBootOverlayInner">
        <div class="shellBootHeaderSpacer"></div>
        <ShellSilhouetteGrid
          items={initialSilhouetteLayout}
          layoutSettings={initialShellSettings.layoutSettings}
          animate={true}
        />
      </div>
    </div>
    <JuliaHeader quote={initialQuote} greeting={initialGreeting}>
      <Meta slot="meta" client:load initialNowIso={initialNowIso} initialLocale={initialDisplayLocale} />
    </JuliaHeader>
    <ShellApp
      client:load
      initialShellSettings={initialShellSettings}
      initialNowIso={initialNowIso}
    />
  </div>
</Layout>

<script>
  import { setupShellBootOverlay } from '@app/shell/ui/lib/boot-overlay';
  setupShellBootOverlay();
</script>

<style>
  .shellBootStage {
    position: relative;
    --shell-boot-header-height: 5.6rem;
    --widget-card-height-desktop: 435px;
    --radius: 24px;
    --card-bg: #ffffff;
    --card-shadow: 0 14px 36px rgb(148 163 184 / 22%);
  }

  html[data-shell-theme='night'] .shellBootStage,
  body[data-shell-theme='night'] .shellBootStage {
    --card-bg: #101b2d;
    --card-shadow: 0 18px 40px rgb(2 6 23 / 45%);
  }

  .shellBootOverlay {
    position: absolute;
    inset: 0;
    z-index: 80;
    pointer-events: none;
    transition: opacity 220ms ease, visibility 220ms ease;
  }

  .shellBootOverlayInner {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .shellBootHeaderSpacer {
    height: var(--shell-boot-header-height);
    min-height: var(--shell-boot-header-height);
  }

  .shellBootOverlayHidden {
    opacity: 0;
    visibility: hidden;
  }

</style>
