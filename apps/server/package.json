{
  "name": "@julia/server",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "yarn@4.9.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node ./scripts/compress-dist.mjs",
    "build:raw": "astro build",
    "preview": "astro preview",
    "lint": "yarn check:indexes && yarn lint:biome && yarn lint:styles && yarn typecheck",
    "check:indexes": "node ./scripts/check-indexes.mjs",
    "lint:biome": "biome lint .",
    "lint:biome:fix": "biome check --write .",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "lint:styles:fix": "stylelint \"src/**/*.scss\" --fix",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node ./dist/server/entry.mjs",
    "prod:register-task": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/astro-prod-register-task.ps1",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.4",
    "@astrojs/react": "^4.4.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.44.0",
    "@grpc/grpc-js": "^1.14.1",
    "@grpc/proto-loader": "^0.8.0",
    "@infisical/sdk": "^4.0.6",
    "astro": "^5.17.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "ky": "^1.14.3",
    "luxon": "^3.7.2",
    "neverthrow": "^8.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@biomejs/biome": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "postcss": "^8.5.8",
    "sass": "^1.97.3",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
