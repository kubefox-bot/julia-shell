---
import Layout from '../layouts/Layout.astro';
import fs from 'fs/promises';
import path from 'path';
import os from 'os';

const DOWNLOADS_DIR = path.join(os.homedir(), 'Downloads');
const BATUMI_LATITUDE = 41.65;
const BATUMI_LONGITUDE = 41.64;

type ForecastDay = {
	date: string;
	tempMax: number;
	tempMin: number;
	weatherCode: number;
};

function describeWeatherCode(code: number) {
	const labels: Record<number, string> = {
		0: 'Ясно',
		1: 'Почти ясно',
		2: 'Переменная облачность',
		3: 'Пасмурно',
		45: 'Туман',
		48: 'Туман с инеем',
		51: 'Слабая морось',
		53: 'Морось',
		55: 'Сильная морось',
		61: 'Слабый дождь',
		63: 'Дождь',
		65: 'Сильный дождь',
		71: 'Слабый снег',
		73: 'Снег',
		75: 'Сильный снег',
		80: 'Ливни',
		81: 'Ливень',
		82: 'Сильный ливень',
		95: 'Гроза',
		96: 'Гроза с градом',
		99: 'Сильная гроза'
	};

	return labels[code] ?? 'Погода уточняется';
}

function getWeatherMood(code: number) {
	if ([80, 81, 82, 61, 63, 65].includes(code)) {
		return '☔ Придется дома сидеть';
	}

	if ([0, 1].includes(code)) {
		return '☀️ Можно погулять';
	}

	return '✨ Посмотрим по настроению';
}

// Получаем список резюме (последние 10)
let hrFiles: string[] = [];
try {
    const files = await fs.readdir(DOWNLOADS_DIR);
    hrFiles = files
        .filter(f => {
            const low = f.toLowerCase();
            return (low.includes('резюме') || low.includes('соискатель') || low.includes('cv') || low.includes('resume')) && f.endsWith('.pdf');
        })
        .sort(async (a, b) => {
            const statA = await fs.stat(path.join(DOWNLOADS_DIR, a));
            const statB = await fs.stat(path.join(DOWNLOADS_DIR, b));
            return statB.mtimeMs - statA.mtimeMs;
        })
        .slice(0, 10);
} catch (e) {
    console.error('Error reading downloads', e);
}

// Поиск книг для английского (автоматически)
let englishBooks: string[] = [];
try {
    const files = await fs.readdir(DOWNLOADS_DIR);
    englishBooks = files.filter(f => {
        const low = f.toLowerCase();
        return (low.includes('english') || low.includes('учебник') || low.includes('grammar')) && (f.endsWith('.pdf') || f.endsWith('.epub'));
    }).slice(0, 4);
} catch (e) {}

const today = new Intl.DateTimeFormat('ru-RU', { weekday: 'long', day: 'numeric', month: 'long' }).format(new Date());

let batumiForecast: ForecastDay[] = [];
let batumiForecastSummary = 'Не удалось загрузить прогноз.';
let batumiWeatherMood = '✨ Посмотрим по настроению';

try {
	const weatherUrl = new URL('https://api.open-meteo.com/v1/forecast');
	weatherUrl.searchParams.set('latitude', String(BATUMI_LATITUDE));
	weatherUrl.searchParams.set('longitude', String(BATUMI_LONGITUDE));
	weatherUrl.searchParams.set('timezone', 'auto');
	weatherUrl.searchParams.set('forecast_days', '3');
	weatherUrl.searchParams.set('daily', 'weather_code,temperature_2m_max,temperature_2m_min');

	const response = await fetch(weatherUrl, {
		headers: {
			'User-Agent': 'Yulia-Assistant/1.0'
		}
	});

	if (!response.ok) {
		throw new Error(`Weather API returned ${response.status}`);
	}

	const payload = await response.json() as {
		daily?: {
			time?: string[];
			weather_code?: number[];
			temperature_2m_max?: number[];
			temperature_2m_min?: number[];
		};
	};

	const daily = payload.daily;
	if (daily?.time && daily.weather_code && daily.temperature_2m_max && daily.temperature_2m_min) {
		batumiForecast = daily.time.slice(0, 3).map((date, index) => ({
			date,
			tempMax: daily.temperature_2m_max?.[index] ?? 0,
			tempMin: daily.temperature_2m_min?.[index] ?? 0,
			weatherCode: daily.weather_code?.[index] ?? 0
		}));

		if (batumiForecast[0]) {
			batumiForecastSummary = `${describeWeatherCode(batumiForecast[0].weatherCode)}, ${Math.round(batumiForecast[0].tempMax)}° / ${Math.round(batumiForecast[0].tempMin)}°`;
			batumiWeatherMood = getWeatherMood(batumiForecast[0].weatherCode);
		}
	}
} catch (error) {
	console.error('Error loading Batumi forecast', error);
}
---

<Layout title="Yulia Assistant">
	<header class="header">
		<h1>Привет, Юля! ✨</h1>
		<p class="date">{today}</p>
	</header>

	<div class="grid">
		<!-- Карточка: Погода -->
		<div class="card card-wide">
			<div class="icon">🌤️</div>
			<h2>Батуми</h2>
			<p class="weather-summary">{batumiForecastSummary}</p>
			<p class="weather-mood">{batumiWeatherMood}</p>
			<ul class="weather-list">
				{batumiForecast.length > 0 ? batumiForecast.map((day) => (
					<li>
						<span>{new Intl.DateTimeFormat('ru-RU', { weekday: 'short', day: 'numeric', month: 'short' }).format(new Date(day.date))}</span>
						<span>{describeWeatherCode(day.weatherCode)}</span>
						<strong>{Math.round(day.tempMax)}° / {Math.round(day.tempMin)}°</strong>
					</li>
				)) : <li class="empty">Прогноз пока недоступен</li>}
			</ul>
		</div>

		<!-- Карточка: Кандидаты -->
		<div class="card">
			<div class="icon">📄</div>
			<h2>Мои кандидаты</h2>
			<ul class="file-list">
				{hrFiles.length > 0 ? hrFiles.map(file => (
					<li>{file}</li>
				)) : <li class="empty">Пока нет резюме в загрузках</li>}
			</ul>
		</div>

		<!-- Карточка: Английский -->
		<div class="card">
			<div class="icon">🇬🇧</div>
			<h2>English Time</h2>
			<ul class="file-list">
				{englishBooks.length > 0 ? englishBooks.map(file => (
					<li>{file}</li>
				)) : <li class="empty">Учебники не найдены</li>}
			</ul>
			<a href="https://dictionary.cambridge.org/" target="_blank" class="link-btn">Словарь →</a>
		</div>

		<!-- Карточка: Уборка -->
		<div class="card">
			<div class="card-content">
				<div class="icon">🧹</div>
				<h2>Навести порядок</h2>
				<p>Сгруппировать файлы в загрузках по категориям</p>
				<button id="clean-btn" class="btn">Запустить магию</button>
			</div>
			<div id="clean-status" class="status-overlay">Готово! ✨</div>
		</div>

		<!-- Карточка: Книжная полка -->
		<div class="card">
			<div class="icon">📚</div>
			<h2>Книжная полка</h2>
			<p>Доступ к последним книгам (.epub, .fb2)</p>
			<button id="open-btn" class="btn btn-secondary">Открыть папку</button>
		</div>

		<!-- Карточка: Сервер -->
		<div class="card">
			<div class="icon">🖥️</div>
			<h2>Сервер</h2>
			<div class="server-status-row">
				<span id="server-badge" class="server-badge">Проверяю...</span>
				<a id="server-link" href="http://julia.love:4321" target="_blank" class="link-btn server-link">julia.love:4321</a>
			</div>
			<p id="server-message" class="muted-info">Загружаю состояние production...</p>
			<div class="server-meta">
				<p>Task Scheduler: <span id="server-task-state">—</span></p>
				<p>Порт 4321: <span id="server-port-state">—</span></p>
			</div>
			<div class="server-actions">
				<button id="server-start-btn" class="btn btn-secondary small-btn">Запустить</button>
				<button id="server-restart-btn" class="btn small-btn">Перезагрузить</button>
				<button id="server-stop-btn" class="btn btn-secondary small-btn">Остановить</button>
			</div>
			<p class="server-note">Если сайт полностью остановлен, холодный старт делает Windows при следующем входе пользователя.</p>
		</div>

		<!-- Карточка: Подружка -->
		<div class="card">
			<div class="icon">💌</div>
			<h2>Написать своей подружке</h2>
			<div class="friends-list" id="friends-list">
				<button type="button" class="friend-chip selected" data-friend-name="Ирочка" data-friend-username="CHARMING_UNICORN">Ирочка</button>
				<button type="button" class="friend-chip" data-friend-name="Леночка" data-friend-username="Alena_Savele">Леночка</button>
				<button type="button" class="friend-chip" data-friend-name="Так уж и быть Светочке">Так уж и быть Светочке</button>
			</div>
			<p id="friend-status" class="muted-info">Выбрана: Ирочка</p>
			<button id="friend-write-btn" class="btn">Написать пойдем гулять!</button>
		</div>

		<!-- Карточка: Транскрибация -->
		<div class="card card-wide">
			<div class="transcribe-head">
				<div class="transcribe-title">
					<div class="icon">🎙️</div>
					<h2>Транскрибация через Gemini</h2>
				</div>
				<button id="transcribe-settings-toggle" class="icon-btn settings-toggle-btn" type="button" title="Настройки Gemini">⚙️</button>
			</div>
			<div id="transcribe-settings-panel" class="settings-panel hidden">
				<div class="gemini-key-panel">
					<label class="field-label" for="gemini-api-key-input">Gemini API Key</label>
					<div class="path-input-row gemini-key-row">
						<input id="gemini-api-key-input" type="password" placeholder="Вставь Gemini API Key..." autocomplete="off" />
						<button id="gemini-api-key-save-btn" class="btn btn-secondary small-btn">Сохранить</button>
					</div>
				</div>
				<div class="gemini-model-panel">
					<label class="field-label" for="gemini-model-select">Модель Gemini</label>
					<select id="gemini-model-select" class="settings-select">
						<option value="gemini-2.5-flash">gemini-2.5-flash</option>
						<option value="gemini-2.0-flash">gemini-2.0-flash</option>
						<option value="gemini-2.5-pro">gemini-2.5-pro</option>
					</select>
				</div>
				<p id="gemini-api-key-status" class="muted-info">Ключ пока не сохранен на сервере.</p>
			</div>
			<div id="transcribe-setup">
				<div class="path-input-row">
					<input id="browse-path-input" type="text" placeholder="Вставь путь к папке..." autocomplete="off" list="browse-recent-list" />
					<datalist id="browse-recent-list"></datalist>
					<button id="browse-load-btn" class="btn btn-secondary small-btn">Показать</button>
					<button id="browse-up-btn" class="btn btn-secondary small-btn">Вверх</button>
					<button id="browse-clear-btn" class="icon-btn" title="Очистить сохраненный путь">✕</button>
				</div>
				<p class="muted-info">Клик по папке открывает ее содержимое. Клик по файлу `.m4a` выбирает его для транскрибации. Перед отправкой файл сжимается в mono Opus и уходит в Gemini API. Настройки ключа и модели лежат на сервере.</p>
				<ul id="browser-list" class="browser-list"></ul>
				<p class="selected-path">Текущая папка: <span id="selected-folder-path">—</span></p>
				<p class="selected-file">Выбранный файл: <span id="selected-audio-path">—</span></p>
				<div class="progress-wrap hidden" id="transcribe-progress-wrap">
					<div class="progress-bar">
						<div id="transcribe-progress-fill"></div>
					</div>
					<p id="transcribe-progress-text">0%</p>
				</div>
				<div class="transcribe-main-actions">
					<button id="transcribe-btn" class="btn" disabled>Транскрибация</button>
					<button id="transcribe-open-txt-btn" class="btn btn-secondary hidden" type="button">Прочитать</button>
				</div>
			</div>
			<div id="transcribe-result" class="hidden">
				<textarea id="transcribe-text" class="transcribe-text" readonly></textarea>
				<div class="result-actions">
					<button id="transcribe-back-btn" class="btn btn-secondary">Назад</button>
					<button id="transcribe-copy-btn" class="btn">Скопировать</button>
					<button id="transcribe-save-btn" class="btn">Сохранить</button>
				</div>
			</div>
			<p id="transcribe-status" class="transcribe-status">Готово к работе.</p>
		</div>

		<!-- Карточка: Чат с помощником -->
		<div class="card card-wide chat-container">
			<div class="card-content">
				<div class="icon">💬</div>
				<h2>Написать тебе</h2>
				<div class="chat-box" id="chat-box">
					<div class="message assistant">Привет, Юля! Как дела? ✨</div>
				</div>
				<form id="chat-form" class="chat-form">
					<input type="text" id="chat-input" placeholder="Напиши что-нибудь..." required autocomplete="off" />
					<button type="submit" class="send-btn">🚀</button>
				</form>
			</div>
		</div>
	</div>

	<footer class="status-bar" id="status-bar">
		Система готова к работе.
	</footer>
</Layout>

<script>
	const cleanBtn = document.getElementById('clean-btn');
	const openBtn = document.getElementById('open-btn');
	const statusBar = document.getElementById('status-bar');
	const cleanStatus = document.getElementById('clean-status');
	
	const chatForm = document.getElementById('chat-form') as HTMLFormElement | null;
	const chatInput = document.getElementById('chat-input') as HTMLInputElement | null;
	const chatBox = document.getElementById('chat-box') as HTMLDivElement | null;
	const chatSubmitBtn = chatForm?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
	const defaultChatPlaceholder = 'Напиши что-нибудь...';
	const defaultGeminiModel = 'gemini-2.5-flash';
	const transcribeLastPathKey = 'yulia:last-transcribe-path';
	const transcribeRecentPathsKey = 'yulia:transcribe-recent-paths';
	const astroScopeAttr = chatBox?.querySelector('.message')
		?.getAttributeNames()
		.find((name) => name.startsWith('data-astro-cid-')) ?? null;

	const transcribeSettingsToggle = document.getElementById('transcribe-settings-toggle') as HTMLButtonElement | null;
	const transcribeSettingsPanel = document.getElementById('transcribe-settings-panel');
	const geminiApiKeyInput = document.getElementById('gemini-api-key-input') as HTMLInputElement | null;
	const geminiApiKeySaveBtn = document.getElementById('gemini-api-key-save-btn') as HTMLButtonElement | null;
	const geminiModelSelect = document.getElementById('gemini-model-select') as HTMLSelectElement | null;
	const geminiApiKeyStatus = document.getElementById('gemini-api-key-status');
	const browsePathInput = document.getElementById('browse-path-input') as HTMLInputElement | null;
	const browseRecentList = document.getElementById('browse-recent-list') as HTMLDataListElement | null;
	const browseLoadBtn = document.getElementById('browse-load-btn') as HTMLButtonElement | null;
	const browseUpBtn = document.getElementById('browse-up-btn') as HTMLButtonElement | null;
	const browseClearBtn = document.getElementById('browse-clear-btn') as HTMLButtonElement | null;
	const browserList = document.getElementById('browser-list') as HTMLUListElement | null;
	const selectedFolderPathEl = document.getElementById('selected-folder-path');
	const selectedAudioPathEl = document.getElementById('selected-audio-path');
	const transcribeBtn = document.getElementById('transcribe-btn') as HTMLButtonElement | null;
	const transcribeOpenTxtBtn = document.getElementById('transcribe-open-txt-btn') as HTMLButtonElement | null;
	const transcribeStatus = document.getElementById('transcribe-status');
	const transcribeProgressWrap = document.getElementById('transcribe-progress-wrap');
	const transcribeProgressFill = document.getElementById('transcribe-progress-fill') as HTMLDivElement | null;
	const transcribeProgressText = document.getElementById('transcribe-progress-text');
	const transcribeSetup = document.getElementById('transcribe-setup');
	const transcribeResult = document.getElementById('transcribe-result');
	const transcribeText = document.getElementById('transcribe-text') as HTMLTextAreaElement | null;
	const transcribeBackBtn = document.getElementById('transcribe-back-btn') as HTMLButtonElement | null;
	const transcribeCopyBtn = document.getElementById('transcribe-copy-btn') as HTMLButtonElement | null;
	const transcribeSaveBtn = document.getElementById('transcribe-save-btn') as HTMLButtonElement | null;
	const serverBadge = document.getElementById('server-badge');
	const serverMessage = document.getElementById('server-message');
	const serverTaskState = document.getElementById('server-task-state');
	const serverPortState = document.getElementById('server-port-state');
	const serverLink = document.getElementById('server-link') as HTMLAnchorElement | null;
	const serverStartBtn = document.getElementById('server-start-btn') as HTMLButtonElement | null;
	const serverRestartBtn = document.getElementById('server-restart-btn') as HTMLButtonElement | null;
	const serverStopBtn = document.getElementById('server-stop-btn') as HTMLButtonElement | null;
	const friendsList = document.getElementById('friends-list') as HTMLDivElement | null;
	const friendStatus = document.getElementById('friend-status');
	const friendWriteBtn = document.getElementById('friend-write-btn') as HTMLButtonElement | null;

	let selectedFolderPath: string | null = null;
	let selectedAudioFilePath: string | null = null;
	let selectedTranscriptTxtPath: string | null = null;
	let lastTranscriptSourceFile: string | null = null;
	let hasServerGeminiApiKey = false;
	let selectedGeminiModel = defaultGeminiModel;
	let transcribeIsLoading = false;
	let transcribeResultLocked = false;
	let transcribeDisplayedText = '';
	let transcribeTypingQueue = '';
	let transcribeTypingTimer: number | null = null;
	let transcribeAwaitingUnlock = false;
	let serverActionLoading = false;
	let selectedFriendName = 'Ирочка';
	let selectedFriendUsername = 'CHARMING_UNICORN';
	let currentBrowserEntries: BrowserEntry[] = [];

	type ServerStatusPayload = {
		appStatus: 'running' | 'stopped';
		taskExists: boolean;
		taskState: string;
		portListening: boolean;
		url: string;
		message: string;
	};

	type GeminiSettingsPayload = {
		hasApiKey: boolean;
		model: string;
	};

	cleanBtn?.addEventListener('click', async () => {
		if (statusBar) statusBar.textContent = 'Магическая уборка началась...';
		
		try {
			const res = await fetch('/api/clean', { method: 'POST' });
			const data = await res.json();
			
			const sizeMB = (data.size / (1024 * 1024)).toFixed(2);
			const message = data.moved > 0 
				? `Уборка завершена! Перемещено файлов: ${data.moved} (${sizeMB} MB)`
				: 'В загрузках уже идеальный порядок! ✨';
			
			if (statusBar) statusBar.textContent = message;
			if (cleanStatus) {
				cleanStatus.classList.add('active');
				setTimeout(() => cleanStatus.classList.remove('active'), 3000);
			}
		} catch (e) {
			if (statusBar) statusBar.textContent = 'Ошибка при уборке :(';
		}
	});

	openBtn?.addEventListener('click', async () => {
		try {
			await fetch('/api/open', { method: 'POST' });
		} catch (e) {
			console.error('Failed to open folder');
		}
	});

	function setSelectedFriend(name: string, username?: string) {
		selectedFriendName = name;
		selectedFriendUsername = username ?? '';
		if (friendStatus) {
			friendStatus.textContent = `Выбрана: ${name}`;
		}

		const chips = friendsList?.querySelectorAll<HTMLButtonElement>('.friend-chip') ?? [];
		for (const chip of chips) {
			chip.classList.toggle('selected', chip.dataset.friendName === name);
		}
	}

	function applyScopedAttr(element: HTMLElement) {
		if (astroScopeAttr) {
			element.setAttribute(astroScopeAttr, '');
		}
	}

	function setTranscribeStatus(text: string) {
		if (transcribeStatus) transcribeStatus.textContent = text;
	}

	function scrollTranscribeTextToBottom() {
		if (!transcribeText) return;
		transcribeText.scrollTop = transcribeText.scrollHeight;
	}

	function syncTranscribeTextValue() {
		if (!transcribeText) return;
		transcribeText.value = transcribeDisplayedText;
		scrollTranscribeTextToBottom();
	}

	function stopTranscribeTypewriter() {
		if (transcribeTypingTimer !== null) {
			window.clearTimeout(transcribeTypingTimer);
			transcribeTypingTimer = null;
		}
	}

	function getTranscriptTxtPath(audioPath: string) {
		return audioPath.replace(/\.m4a$/i, '.txt');
	}

	function setSelectedTranscriptTxtPath(pathValue: string | null) {
		selectedTranscriptTxtPath = pathValue;
		if (!transcribeOpenTxtBtn) return;
		const shouldShow = Boolean(pathValue);
		transcribeOpenTxtBtn.classList.toggle('hidden', !shouldShow);
		transcribeOpenTxtBtn.disabled = transcribeIsLoading || !shouldShow;
	}

	function renderGeminiSettingsStatus() {
		if (geminiApiKeyStatus) {
			geminiApiKeyStatus.textContent = hasServerGeminiApiKey
				? `Ключ сохранен на сервере. Активная модель: ${selectedGeminiModel}.`
				: 'Ключ пока не сохранен на сервере.';
		}
		if (geminiModelSelect) {
			geminiModelSelect.value = selectedGeminiModel;
		}
		updateTranscribeAvailability();
	}

	async function loadGeminiSettings() {
		try {
			const response = await fetch('/api/gemini-settings');
			const data = await response.json() as Partial<GeminiSettingsPayload>;
			if (!response.ok) {
				throw new Error(data?.error || 'Не удалось загрузить Gemini settings.');
			}
			hasServerGeminiApiKey = Boolean(data?.hasApiKey);
			selectedGeminiModel = typeof data?.model === 'string' && data.model ? data.model : defaultGeminiModel;
			renderGeminiSettingsStatus();
		} catch (error) {
			hasServerGeminiApiKey = false;
			selectedGeminiModel = defaultGeminiModel;
			if (geminiApiKeyStatus) {
				const message = error instanceof Error ? error.message : 'Не удалось загрузить настройки.';
				geminiApiKeyStatus.textContent = `Ошибка настроек: ${message}`;
			}
			updateTranscribeAvailability();
		}
	}

	async function saveGeminiSettings() {
		const apiKey = geminiApiKeyInput?.value.trim() ?? '';
		const model = geminiModelSelect?.value || defaultGeminiModel;
		if (geminiApiKeySaveBtn) geminiApiKeySaveBtn.disabled = true;
		if (geminiModelSelect) geminiModelSelect.disabled = true;

		try {
			const response = await fetch('/api/gemini-settings', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					apiKey,
					model
				})
			});
			const data = await response.json();
			if (!response.ok) {
				throw new Error(data?.error || 'Не удалось сохранить Gemini settings.');
			}
			hasServerGeminiApiKey = Boolean(data?.hasApiKey);
			selectedGeminiModel = typeof data?.model === 'string' && data.model ? data.model : defaultGeminiModel;
			if (geminiApiKeyInput) {
				geminiApiKeyInput.value = '';
				geminiApiKeyInput.placeholder = hasServerGeminiApiKey
					? 'Ключ уже сохранен на сервере. Вставь новый, если хочешь заменить.'
					: 'Вставь Gemini API Key...';
			}
			renderGeminiSettingsStatus();
			setTranscribeStatus(hasServerGeminiApiKey
				? 'Gemini settings сохранены на сервере.'
				: 'Сохрани Gemini API Key, чтобы запускать транскрибацию.');
		} catch (error) {
			const message = error instanceof Error ? error.message : 'Ошибка сохранения настроек.';
			if (geminiApiKeyStatus) {
				geminiApiKeyStatus.textContent = `Ошибка настроек: ${message}`;
			}
			setTranscribeStatus(`Ошибка: ${message}`);
		} finally {
			if (geminiApiKeySaveBtn) geminiApiKeySaveBtn.disabled = false;
			if (geminiModelSelect) geminiModelSelect.disabled = false;
		}
	}

	function setServerButtonsDisabled(disabled: boolean) {
		if (serverStartBtn) serverStartBtn.disabled = disabled;
		if (serverRestartBtn) serverRestartBtn.disabled = disabled;
		if (serverStopBtn) serverStopBtn.disabled = disabled;
	}

	function renderServerStatus(status: ServerStatusPayload | null, unreachable = false) {
		if (!serverBadge || !serverMessage || !serverTaskState || !serverPortState) return;

		serverBadge.classList.remove('is-running', 'is-stopped', 'is-warning');

		if (!status) {
			serverBadge.textContent = 'Недоступен';
			serverBadge.classList.add('is-warning');
			serverMessage.textContent = unreachable
				? 'Сервер перестал отвечать. После полной остановки панель уже не может поднять его сама.'
				: 'Статус сервера недоступен.';
			serverTaskState.textContent = '—';
			serverPortState.textContent = '—';
			if (serverLink) serverLink.href = 'http://julia.love:4321';
			setServerButtonsDisabled(true);
			return;
		}

		serverBadge.textContent = status.appStatus === 'running' ? 'Работает' : 'Не работает';
		serverBadge.classList.add(status.appStatus === 'running' ? 'is-running' : 'is-stopped');
		serverMessage.textContent = status.message;
		serverTaskState.textContent = status.taskExists ? status.taskState : 'Missing';
		serverPortState.textContent = status.portListening ? 'Слушает' : 'Не слушает';
		if (serverLink) serverLink.href = status.url;

		if (!serverActionLoading) {
			if (serverStartBtn) serverStartBtn.disabled = status.taskState === 'Running';
			if (serverRestartBtn) serverRestartBtn.disabled = false;
			if (serverStopBtn) {
				serverStopBtn.disabled = status.appStatus !== 'running' && status.taskState !== 'Running';
			}
		}
	}

	async function refreshServerStatus() {
		try {
			const response = await fetch('/api/server-status');
			const data = await response.json();
			if (!response.ok) {
				throw new Error(data?.error || 'Не удалось получить статус.');
			}
			renderServerStatus(data as ServerStatusPayload);
		} catch (error) {
			renderServerStatus(null, true);
		}
	}

	async function runServerAction(action: 'start' | 'restart' | 'stop') {
		serverActionLoading = true;
		setServerButtonsDisabled(true);

		if (serverMessage) {
			serverMessage.textContent = action === 'restart'
				? 'Перезапускаю production и пересобираю проект...'
				: action === 'stop'
					? 'Останавливаю production...'
					: 'Запускаю production...';
		}

		try {
			const response = await fetch('/api/server-control', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ action })
			});
			const data = await response.json();
			if (!response.ok) {
				throw new Error(data?.error || 'Команда не выполнилась.');
			}
			if (statusBar) statusBar.textContent = data.message || 'Команда для сервера отправлена.';
		} catch (error) {
			const message = error instanceof Error ? error.message : 'Ошибка управления сервером.';
			if (statusBar) statusBar.textContent = `Ошибка: ${message}`;
			if (serverMessage) serverMessage.textContent = `Ошибка: ${message}`;
		} finally {
			window.setTimeout(() => {
				serverActionLoading = false;
				void refreshServerStatus();
			}, action === 'stop' ? 2500 : 1500);
		}
	}

	function setTranscribeProgress(percent: number, label?: string) {
		const safePercent = Math.max(0, Math.min(100, Math.round(percent)));
		if (transcribeProgressFill) {
			transcribeProgressFill.style.width = `${safePercent}%`;
		}
		if (transcribeProgressText) {
			transcribeProgressText.textContent = label ? `${safePercent}% · ${label}` : `${safePercent}%`;
		}
	}

	function showTranscribeProgress(show: boolean) {
		if (!transcribeProgressWrap) return;
		transcribeProgressWrap.classList.toggle('hidden', !show);
		if (!show) setTranscribeProgress(0);
	}

	function getRecentPaths(): string[] {
		const raw = localStorage.getItem(transcribeRecentPathsKey);
		if (!raw) return [];
		try {
			const parsed = JSON.parse(raw);
			if (!Array.isArray(parsed)) return [];
			return parsed
				.filter((item): item is string => typeof item === 'string' && item.trim().length > 0)
				.slice(-5);
		} catch {
			return [];
		}
	}

	function renderRecentPaths() {
		if (!browseRecentList) return;
		browseRecentList.innerHTML = '';
		for (const pathValue of [...getRecentPaths()].reverse()) {
			const option = document.createElement('option');
			option.value = pathValue;
			browseRecentList.appendChild(option);
		}
	}

	function rememberPath(pathValue: string) {
		if (!pathValue) return;
		localStorage.setItem(transcribeLastPathKey, pathValue);
		const recent = getRecentPaths().filter((item) => item !== pathValue);
		recent.push(pathValue);
		while (recent.length > 5) recent.shift();
		localStorage.setItem(transcribeRecentPathsKey, JSON.stringify(recent));
		renderRecentPaths();
	}

	function updateTranscribeAvailability() {
		if (!transcribeBtn) return;
		transcribeBtn.disabled = transcribeIsLoading || !selectedFolderPath || !selectedAudioFilePath || !hasServerGeminiApiKey;
		if (transcribeOpenTxtBtn) {
			transcribeOpenTxtBtn.disabled = transcribeIsLoading || !selectedTranscriptTxtPath;
		}
	}

	function setSelectedFolder(pathValue: string | null) {
		selectedFolderPath = pathValue;
		if (selectedFolderPathEl) {
			selectedFolderPathEl.textContent = pathValue ?? '—';
		}
		updateTranscribeAvailability();
	}

	function setSelectedAudioFile(pathValue: string | null) {
		selectedAudioFilePath = pathValue;
		if (selectedAudioPathEl) {
			selectedAudioPathEl.textContent = pathValue ?? '—';
		}
		if (!pathValue) {
			setSelectedTranscriptTxtPath(null);
		} else {
			const txtPath = getTranscriptTxtPath(pathValue);
			const hasTxt = currentBrowserEntries.some((entry) => entry.type === 'file' && entry.path.toLowerCase() === txtPath.toLowerCase());
			setSelectedTranscriptTxtPath(hasTxt ? txtPath : null);
		}
		updateTranscribeAvailability();
	}

	function setTranscribeLoading(loading: boolean) {
		transcribeIsLoading = loading;
		if (transcribeSettingsToggle) transcribeSettingsToggle.disabled = loading;
		if (geminiApiKeySaveBtn) geminiApiKeySaveBtn.disabled = loading;
		if (geminiApiKeyInput) geminiApiKeyInput.disabled = loading;
		if (geminiModelSelect) geminiModelSelect.disabled = loading;
		if (browseLoadBtn) browseLoadBtn.disabled = loading;
		if (browseUpBtn) browseUpBtn.disabled = loading;
		if (browseClearBtn) browseClearBtn.disabled = loading;
		if (browsePathInput) browsePathInput.disabled = loading;
		if (transcribeOpenTxtBtn) transcribeOpenTxtBtn.disabled = loading || !selectedTranscriptTxtPath;
		updateTranscribeAvailability();
	}

	function setTranscribeResultLocked(locked: boolean) {
		transcribeResultLocked = locked;
		if (transcribeBackBtn) transcribeBackBtn.disabled = locked;
		if (transcribeCopyBtn) transcribeCopyBtn.disabled = locked;
		if (transcribeSaveBtn) transcribeSaveBtn.disabled = locked;
		if (transcribeText) transcribeText.readOnly = locked;
	}

	function openTranscribeSetup() {
		stopTranscribeTypewriter();
		transcribeDisplayedText = '';
		transcribeTypingQueue = '';
		transcribeAwaitingUnlock = false;
		lastTranscriptSourceFile = null;
		syncTranscribeTextValue();
		setTranscribeResultLocked(false);
		transcribeSetup?.classList.remove('hidden');
		transcribeResult?.classList.add('hidden');
		showTranscribeProgress(false);
	}

	function openTranscribeResult(transcript: string, sourceFile: string, lockActions = false) {
		transcribeDisplayedText = transcript;
		syncTranscribeTextValue();
		if (sourceFile) {
			lastTranscriptSourceFile = sourceFile;
		}
		setTranscribeResultLocked(lockActions);
		transcribeSetup?.classList.add('hidden');
		transcribeResult?.classList.remove('hidden');
	}

	function getTypewriterBatchSize() {
		if (transcribeTypingQueue.length > 240) return 14;
		if (transcribeTypingQueue.length > 120) return 10;
		if (transcribeTypingQueue.length > 40) return 6;
		return 3;
	}

	function finalizeTranscribeTyping() {
		if (transcribeTypingQueue.length > 0) return;
		if (!transcribeAwaitingUnlock) return;
		transcribeAwaitingUnlock = false;
		setTranscribeResultLocked(false);
	}

	function pumpTranscribeTypewriter() {
		if (transcribeTypingQueue.length === 0) {
			transcribeTypingTimer = null;
			finalizeTranscribeTyping();
			return;
		}

		const batchSize = getTypewriterBatchSize();
		transcribeDisplayedText += transcribeTypingQueue.slice(0, batchSize);
		transcribeTypingQueue = transcribeTypingQueue.slice(batchSize);
		syncTranscribeTextValue();
		transcribeTypingTimer = window.setTimeout(pumpTranscribeTypewriter, 22);
	}

	function ensureTranscribeTypewriterRunning() {
		if (transcribeTypingTimer !== null) return;
		transcribeTypingTimer = window.setTimeout(pumpTranscribeTypewriter, 22);
	}

	function queueTranscriptChunk(text: string) {
		if (!text) return;
		transcribeTypingQueue += text;
		if (transcribeResult?.classList.contains('hidden')) {
			openTranscribeResult(transcribeDisplayedText, '', true);
		}
		setTranscribeResultLocked(true);
		ensureTranscribeTypewriterRunning();
	}

	function applyFinalTranscript(finalTranscript: string, sourceFile: string) {
		const alreadyKnownText = transcribeDisplayedText + transcribeTypingQueue;
		if (finalTranscript && finalTranscript !== alreadyKnownText) {
			if (finalTranscript.startsWith(alreadyKnownText)) {
				transcribeTypingQueue += finalTranscript.slice(alreadyKnownText.length);
			} else {
				transcribeDisplayedText = '';
				transcribeTypingQueue = finalTranscript;
				syncTranscribeTextValue();
			}
		}
		if (sourceFile) {
			lastTranscriptSourceFile = sourceFile;
		}
		if (transcribeResult?.classList.contains('hidden')) {
			openTranscribeResult(transcribeDisplayedText, sourceFile, true);
		}
		transcribeAwaitingUnlock = true;
		if (transcribeTypingQueue.length === 0 && transcribeTypingTimer === null) {
			finalizeTranscribeTyping();
			return;
		}
		ensureTranscribeTypewriterRunning();
	}

	type BrowserEntry = {
		name: string;
		path: string;
		type: 'dir' | 'file';
	};

	function renderEntries(entries: BrowserEntry[]) {
		if (!browserList) return;
		browserList.innerHTML = '';

		if (entries.length === 0) {
			const empty = document.createElement('li');
			empty.textContent = 'Папка пустая.';
			empty.className = 'empty';
			applyScopedAttr(empty);
			browserList.appendChild(empty);
			return;
		}

		for (const entry of entries) {
			const li = document.createElement('li');
			const button = document.createElement('button');
			button.type = 'button';
			const isM4a = entry.type === 'file' && entry.name.toLowerCase().endsWith('.m4a');
			button.className = `browser-entry ${entry.type === 'dir' ? 'is-dir' : 'is-file'} ${isM4a ? 'is-audio' : ''}`;
			button.textContent = `${entry.type === 'dir' ? '📁' : '📄'} ${entry.name}`;
			button.dataset.path = entry.path;
			button.dataset.entryType = entry.type;

			if (isM4a && selectedAudioFilePath && entry.path === selectedAudioFilePath) {
				button.classList.add('selected');
			}

			button.addEventListener('click', async () => {
				if (entry.type === 'dir') {
					await loadPathEntries(entry.path);
					return;
				}

				if (!isM4a) {
					setTranscribeStatus('Выбери файл формата .m4a.');
					return;
				}

				setSelectedAudioFile(entry.path);
				renderEntries(entries);
				const transcriptTxtPath = getTranscriptTxtPath(entry.path);
				const hasTranscriptTxt = entries.some((item) => item.type === 'file' && item.path.toLowerCase() === transcriptTxtPath.toLowerCase());
				setTranscribeStatus(hasTranscriptTxt
					? `Выбран файл: ${entry.name}. Можно запускать транскрибацию или открыть готовый .txt.`
					: `Выбран файл: ${entry.name}. Теперь можно запускать транскрибацию.`);
			});

			applyScopedAttr(li);
			applyScopedAttr(button);
			li.appendChild(button);
			browserList.appendChild(li);
		}
	}

	async function loadPathEntries(rawPath: string) {
		const inputPath = rawPath.trim();
		if (!inputPath) {
			setTranscribeStatus('Вставь путь к папке.');
			return;
		}

		setTranscribeStatus('Загружаю содержимое...');
		setSelectedFolder(null);
		setSelectedAudioFile(null);
		currentBrowserEntries = [];

		try {
			const response = await fetch('/api/fs-list', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ path: inputPath })
			});
			const data = await response.json();

			if (!response.ok) {
				throw new Error(data?.error || 'Не удалось прочитать путь.');
			}

			const entries = data.entries as BrowserEntry[];
			currentBrowserEntries = entries;
			if (browsePathInput) browsePathInput.value = data.path;
			rememberPath(data.path as string);
			renderEntries(entries);
			setSelectedFolder(data.path as string);
			const hasM4a = entries.some((entry) => entry.type === 'file' && entry.name.toLowerCase().endsWith('.m4a'));
			setTranscribeStatus(hasM4a
				? 'Папка открыта. Выбери .m4a файл вручную для транскрибации.'
				: 'Папка открыта, но .m4a файлов не найдено.');
		} catch (error) {
			const message = error instanceof Error ? error.message : 'Ошибка чтения пути.';
			setTranscribeStatus(`Ошибка: ${message}`);
			if (browserList) browserList.innerHTML = '';
		}
	}

	browseLoadBtn?.addEventListener('click', async () => {
		await loadPathEntries(browsePathInput?.value ?? '');
	});

	browseUpBtn?.addEventListener('click', async () => {
		const current = (browsePathInput?.value ?? '').replace(/[\\\/]+$/, '');
		if (!current) return;

		const idx = current.lastIndexOf('\\');
		if (idx <= 2) {
			await loadPathEntries(current);
			return;
		}

		await loadPathEntries(current.slice(0, idx));
	});

	browsePathInput?.addEventListener('keydown', async (event) => {
		if (event.key !== 'Enter') return;
		event.preventDefault();
		await loadPathEntries(browsePathInput.value);
	});

	browseClearBtn?.addEventListener('click', () => {
		localStorage.removeItem(transcribeLastPathKey);
		localStorage.removeItem(transcribeRecentPathsKey);
		renderRecentPaths();
		if (browsePathInput) browsePathInput.value = '';
		if (browserList) browserList.innerHTML = '';
		currentBrowserEntries = [];
		setSelectedFolder(null);
		setSelectedAudioFile(null);
		showTranscribeProgress(false);
		setTranscribeStatus('Сохраненный путь очищен.');
	});

	transcribeSettingsToggle?.addEventListener('click', () => {
		transcribeSettingsPanel?.classList.toggle('hidden');
	});

	geminiApiKeySaveBtn?.addEventListener('click', () => {
		void saveGeminiSettings();
	});

	async function consumeTranscribeSse(stream: ReadableStream<Uint8Array>) {
		const reader = stream.getReader();
		const decoder = new TextDecoder();
		let buffer = '';
		let finished = false;
		let transcript = '';
		let sourceFile = '';

		const processEvent = (eventChunk: string) => {
			const lines = eventChunk.split('\n');
			let eventName = 'message';
			const dataLines: string[] = [];

			for (const rawLine of lines) {
				const line = rawLine.trimEnd();
				if (line.startsWith('event:')) {
					eventName = line.slice(6).trim();
				} else if (line.startsWith('data:')) {
					dataLines.push(line.slice(5).trimStart());
				}
			}

			if (dataLines.length === 0) return;

			let payload: Record<string, unknown> = {};
			try {
				payload = JSON.parse(dataLines.join('\n')) as Record<string, unknown>;
			} catch {
				return;
			}

			if (eventName === 'progress') {
				const percent = typeof payload.percent === 'number' ? payload.percent : 0;
				const stage = typeof payload.stage === 'string' ? payload.stage : undefined;
				showTranscribeProgress(true);
				setTranscribeProgress(percent, stage);
				return;
			}

			if (eventName === 'token') {
				const text = typeof payload.text === 'string' ? payload.text : '';
				if (!text) return;
				transcript += text;
				queueTranscriptChunk(text);
				setTranscribeStatus('Gemini печатает стенограмму...');
				return;
			}

			if (eventName === 'done') {
				finished = true;
				const finalTranscript = typeof payload.transcript === 'string' ? payload.transcript : '';
				if (finalTranscript) {
					transcript = finalTranscript;
				}
				sourceFile = typeof payload.sourceFile === 'string' ? payload.sourceFile : '';
				applyFinalTranscript(transcript, sourceFile);
				return;
			}

			if (eventName === 'error') {
				const message = typeof payload.message === 'string' ? payload.message : 'Ошибка транскрибации.';
				throw new Error(message);
			}
		};

		while (true) {
			const { done, value } = await reader.read();
			if (done) break;

			buffer += decoder.decode(value, { stream: true }).replace(/\r/g, '');

			while (true) {
				const boundary = buffer.indexOf('\n\n');
				if (boundary === -1) break;
				const chunk = buffer.slice(0, boundary);
				buffer = buffer.slice(boundary + 2);
				processEvent(chunk);
			}
		}

		if (buffer.trim()) processEvent(buffer);

		if (!finished) {
			throw new Error('Поток завершился без результата.');
		}

		return { transcript, sourceFile };
	}

	transcribeBtn?.addEventListener('click', async () => {
		if (!selectedFolderPath) {
			setTranscribeStatus('Сначала открой папку.');
			return;
		}
		if (!selectedAudioFilePath) {
			setTranscribeStatus('Сначала выбери .m4a файл.');
			return;
		}
		if (!hasServerGeminiApiKey) {
			setTranscribeStatus('Сначала сохрани Gemini API Key в шестеренке.');
			return;
		}

		stopTranscribeTypewriter();
		transcribeDisplayedText = '';
		transcribeTypingQueue = '';
		transcribeAwaitingUnlock = false;
		syncTranscribeTextValue();
		setTranscribeLoading(true);
		setTranscribeStatus('Идет процесс транскрибации...');
		showTranscribeProgress(true);
		setTranscribeProgress(1, 'Запуск...');

		try {
			const response = await fetch('/api/transcribe-stream', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					folderPath: selectedFolderPath,
					filePath: selectedAudioFilePath
				})
			});

			if (!response.ok) {
				const data = await response.json().catch(() => null);
				throw new Error(data?.error || 'Транскрибация не удалась.');
			}

			if (!response.body) throw new Error('Транскрибация не удалась.');

			const result = await consumeTranscribeSse(response.body);
			applyFinalTranscript(result.transcript, result.sourceFile);
			setTranscribeProgress(100, 'Готово');
			setTranscribeStatus('Готово.');
		} catch (error) {
			setTranscribeResultLocked(false);
			const message = error instanceof Error ? error.message : 'Ошибка транскрибации.';
			setTranscribeStatus(`Ошибка: ${message}`);
		} finally {
			setTranscribeLoading(false);
		}
	});

	transcribeOpenTxtBtn?.addEventListener('click', async () => {
		if (!selectedAudioFilePath || !selectedTranscriptTxtPath) {
			setTranscribeStatus('Рядом с выбранным аудио пока нет .txt файла.');
			return;
		}

		setTranscribeLoading(true);
		setTranscribeStatus('Открываю готовую стенограмму из .txt...');
		showTranscribeProgress(false);

		try {
			const response = await fetch('/api/transcript-read', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					sourceFile: selectedAudioFilePath
				})
			});
			const data = await response.json();
			if (!response.ok) {
				throw new Error(data?.error || 'Не удалось открыть .txt файл.');
			}

			stopTranscribeTypewriter();
			transcribeDisplayedText = typeof data?.transcript === 'string' ? data.transcript : '';
			transcribeTypingQueue = '';
			transcribeAwaitingUnlock = false;
			openTranscribeResult(transcribeDisplayedText, selectedAudioFilePath, false);
			setTranscribeStatus(`Открыт файл: ${data?.txtPath || selectedTranscriptTxtPath}`);
		} catch (error) {
			const message = error instanceof Error ? error.message : 'Ошибка чтения .txt файла.';
			setTranscribeStatus(`Ошибка: ${message}`);
		} finally {
			setTranscribeLoading(false);
		}
	});

	transcribeBackBtn?.addEventListener('click', () => {
		openTranscribeSetup();
		setTranscribeStatus('Вернулись к выбору папки.');
	});

	transcribeCopyBtn?.addEventListener('click', async () => {
		if (!transcribeText?.value) return;
		try {
			await navigator.clipboard.writeText(transcribeText.value);
			setTranscribeStatus('Текст скопирован.');
		} catch {
			setTranscribeStatus('Не удалось скопировать текст.');
		}
	});

	transcribeSaveBtn?.addEventListener('click', async () => {
		if (!transcribeText?.value || !lastTranscriptSourceFile) {
			setTranscribeStatus('Нет данных для сохранения.');
			return;
		}

		try {
			const response = await fetch('/api/transcribe-save', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					sourceFile: lastTranscriptSourceFile,
					transcript: transcribeText.value
				})
			});
			const data = await response.json();
			if (!response.ok) throw new Error(data?.error || 'Не удалось сохранить файл.');
			if (typeof data?.savePath === 'string' && data.savePath) {
				setSelectedTranscriptTxtPath(data.savePath);
				if (!currentBrowserEntries.some((entry) => entry.type === 'file' && entry.path.toLowerCase() === data.savePath.toLowerCase())) {
					currentBrowserEntries.push({
						name: data.savePath.split(/[\\/]/).pop() ?? data.savePath,
						path: data.savePath,
						type: 'file'
					});
				}
			}
			setTranscribeStatus(`Сохранено: ${data.savePath}`);
		} catch (error) {
			const message = error instanceof Error ? error.message : 'Ошибка сохранения.';
			setTranscribeStatus(`Ошибка: ${message}`);
		}
	});

	serverStartBtn?.addEventListener('click', () => {
		void runServerAction('start');
	});

	serverRestartBtn?.addEventListener('click', () => {
		void runServerAction('restart');
	});

	serverStopBtn?.addEventListener('click', () => {
		void runServerAction('stop');
	});

	friendsList?.addEventListener('click', (event) => {
		const target = event.target;
		if (!(target instanceof HTMLButtonElement)) return;
		const name = target.dataset.friendName;
		const username = target.dataset.friendUsername;
		if (!name) return;
		setSelectedFriend(name, username);
	});

	friendWriteBtn?.addEventListener('click', () => {
		if (!selectedFriendUsername) {
			window.alert('Светочка не добавила userName. Вот старость, а');
			return;
		}
		const telegramUrl = `https://web.telegram.org/a/#@${selectedFriendUsername}`;
		window.open(telegramUrl, '_blank', 'noopener,noreferrer');
		if (statusBar) {
			statusBar.textContent = `${selectedFriendName} ждет сообщение "пойдем гулять!" в Telegram.`;
		}
	});

	renderRecentPaths();
	void loadGeminiSettings();
	const savedPath = localStorage.getItem(transcribeLastPathKey);
	const defaultBrowsePath = 'C:\\Users\\julia\\OneDrive\\Рабочий стол';
	if (browsePathInput) {
		browsePathInput.value = savedPath || defaultBrowsePath;
	}

	openTranscribeSetup();
	setTranscribeStatus('Открой шестеренку, сохрани Gemini API Key, затем выбери .m4a файл.');
	if (browsePathInput?.value) {
		void loadPathEntries(browsePathInput.value);
	}
	void refreshServerStatus();
	window.setInterval(() => {
		void refreshServerStatus();
	}, 5000);

	chatForm?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const message = chatInput?.value.trim() ?? '';
		if (!message) return;

		// Добавляем сообщение пользователя
		addMessage(message, 'user');
		if (chatInput) chatInput.value = '';
		const assistantMessage = addMessage('', 'assistant', 'streaming');
		setChatLoading(true);

		try {
			const res = await fetch('/api/chat', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ message })
			});

			if (!res.ok || !res.body) {
				throw new Error('Failed to open SSE stream');
			}

			await consumeSseStream(res.body, assistantMessage);
		} catch (e) {
			assistantMessage.classList.remove('streaming');
			assistantMessage.textContent = 'Ой, что-то пошло не так... попробуй еще раз!';
		} finally {
			setChatLoading(false);
		}
	});

	async function consumeSseStream(stream: ReadableStream<Uint8Array>, msgDiv: HTMLDivElement) {
		const reader = stream.getReader();
		const decoder = new TextDecoder();
		let buffer = '';
		let gotDone = false;

		while (true) {
			const { done, value } = await reader.read();
			if (done) break;

			buffer += decoder.decode(value, { stream: true }).replace(/\r/g, '');

			while (true) {
				const boundary = buffer.indexOf('\n\n');
				if (boundary === -1) break;

				const eventChunk = buffer.slice(0, boundary);
				buffer = buffer.slice(boundary + 2);
				gotDone = processSseEvent(eventChunk, msgDiv) || gotDone;
			}
		}

		if (buffer.trim()) {
			gotDone = processSseEvent(buffer, msgDiv) || gotDone;
		}

		msgDiv.classList.remove('streaming');
		if (!gotDone && !msgDiv.textContent?.trim()) {
			msgDiv.textContent = 'Пустой ответ от Gemini.';
		}
	}

	function processSseEvent(rawEvent: string, msgDiv: HTMLDivElement): boolean {
		const lines = rawEvent.split('\n');
		let eventName = 'message';
		const dataLines: string[] = [];

		for (const rawLine of lines) {
			const line = rawLine.trimEnd();
			if (line.startsWith('event:')) {
				eventName = line.slice(6).trim();
			} else if (line.startsWith('data:')) {
				dataLines.push(line.slice(5).trimStart());
			}
		}

		if (dataLines.length === 0) return false;

		let payload: { text?: string; message?: string } = {};
		try {
			payload = JSON.parse(dataLines.join('\n'));
		} catch {
			return false;
		}

		if (eventName === 'token') {
			if (typeof payload.text === 'string') {
				msgDiv.textContent += payload.text;
				if (chatBox) chatBox.scrollTop = chatBox.scrollHeight;
			}
			return false;
		}

		if (eventName === 'error') {
			msgDiv.classList.remove('streaming');
			msgDiv.textContent = typeof payload.message === 'string'
				? `Ошибка: ${payload.message}`
				: 'Ошибка потока Gemini.';
			return true;
		}

		if (eventName === 'done') {
			msgDiv.classList.remove('streaming');
			if (!msgDiv.textContent?.trim()) {
				msgDiv.textContent = 'Gemini не вернул текст.';
			}
			return true;
		}

		return false;
	}

	function setChatLoading(loading: boolean) {
		if (chatInput) {
			chatInput.disabled = loading;
			chatInput.placeholder = loading ? 'Gemini печатает в реальном времени...' : defaultChatPlaceholder;
		}
		if (chatSubmitBtn) {
			chatSubmitBtn.disabled = loading;
		}
	}

	function addMessage(text: string, role: 'user' | 'assistant', extraClass = ''): HTMLDivElement {
		const msgDiv = document.createElement('div');
		msgDiv.className = `message ${role} ${extraClass}`.trim();
		if (astroScopeAttr) {
			msgDiv.setAttribute(astroScopeAttr, '');
		}
		msgDiv.textContent = text;
		if (!chatBox) return msgDiv;
		chatBox.appendChild(msgDiv);
		chatBox.scrollTop = chatBox.scrollHeight;
		return msgDiv;
	}
</script>

